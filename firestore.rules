rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Alle gebruikersdata zit onder users/{userId}/...
    // Enkel de eigenaar (ingelogde gebruiker) mag zijn eigen data lezen en schrijven.
    match /users/{userId}/{document=**} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Alle andere paden zijn standaard verboden (geen expliciete regel = deny).
  }
}
