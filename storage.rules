rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {

    // Alleen de eigenaar mag zijn eigen cover-afbeeldingen lezen en schrijven.
    match /users/{userId}/covers/{file} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Alle andere paden zijn standaard verboden.
  }
}
